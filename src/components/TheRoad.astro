---
// THE ROAD — the landing. Faithful production port of the approved
// prototypes/01-valley/the-road.html: warm world, curved "comet road",
// amber in exactly three homes. Copy is the single locked source in road.ts.
import { intro, stages, close, footer } from '../lib/road';

// Strip the [brackets] around the single emphasised phrase per stage and colour
// that run amber (amber home #2). Content is authored locally, never user input.
function emph(s: string): string {
  const esc = s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return esc.replace(/\[(.+?)\]/g, '<em class="accent">$1</em>');
}

// Approved image set — self-hosted, resized to WebP (scripts/optimize-images).
// Each <img> degrades to a warm graded panel if it fails to load.
const media: Record<string, string> = {
  intro: '/road/intro.webp',
  s1: '/road/s1.webp',
  s2: '/road/s2.webp',
  s3: '/road/s3.webp',
  s4: '/road/s4.webp',
  close: '/road/close.webp',
};
const photoCredits = [
  { name: 'Barnaby Woodrow', profile: 'https://unsplash.com/@cranky_bear' },
  { name: 'Abhishek R', profile: 'https://unsplash.com/@intheshot' },
  { name: 'Leon Seibert', profile: 'https://unsplash.com/@yapics' },
  { name: 'Ozren Cuculic', profile: 'https://unsplash.com/@ozren_c' },
  { name: 'Leo', profile: 'https://unsplash.com/@ocuole' },
  { name: 'Andrey Metelev', profile: 'https://unsplash.com/@metelevan' },
];
---

<main id="main" tabindex="-1">
  <!-- ROAD OVERLAY (decorative; path built from live section offsets in JS) -->
  <svg id="road" aria-hidden="true" role="presentation" preserveAspectRatio="xMidYMid meet">
    <path id="road-ghost" d=""></path>
    <path id="road-fill" d=""></path>
    <g id="road-head">
      <circle class="head-halo" r="13" cx="-50" cy="-50"></circle>
      <circle class="head-core" r="4.5" cx="-50" cy="-50"></circle>
    </g>
  </svg>

  <div class="valley-dim" aria-hidden="true"></div>

  <!-- INTRO -->
  <section class="scene scene--left scene--intro" id="intro" data-road="intro" aria-labelledby="intro-title">
    <div class="scene__media">
      <img src={media.intro} alt="" loading="eager" fetchpriority="high" decoding="async" onerror="this.style.display='none'" />
    </div>
    <div class="scene__grade"></div>
    <div class="scene__scrim"></div>
    <div class="wrap"><div class="panel">
      <p class="ident reveal">{intro.ident}</p>
      <h1 class="intro-title reveal" id="intro-title"><span class="br">The</span> road.</h1>
      <p class="lede reveal">{intro.body}</p>
    </div></div>
  </section>

  <!-- STAGES 01-04 -->
  {stages.map((s, i) => (
    <section
      class={`scene scene--${s.side}${s.key === 'valley' ? ' scene--valley' : ''}`}
      id={`s${i + 1}`}
      data-road={`s${i + 1}`}
      data-stage
      aria-labelledby={`s${i + 1}-title`}
    >
      <div class="scene__media">
        <img src={media[`s${i + 1}`]} alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" />
      </div>
      <div class="scene__grade"></div>
      <div class="scene__scrim"></div>
      <div class="wrap"><div class="panel">
        <div class="stage-head reveal">
          <span class="stage-num" aria-hidden="true">{s.num}</span>
          <h2 class="stage-title" id={`s${i + 1}-title`}>{s.title}</h2>
        </div>
        <div class="kills reveal">
          <span class="kills__label">{s.killsLabel}</span>
          <ul>{s.kills.map((k) => <li>{k}</li>)}</ul>
        </div>
        <p class="prose reveal" set:html={emph(s.body)}></p>
        <p class="receipt reveal"><span class="receipt__label">Receipt</span>{s.receipt}</p>
      </div></div>
    </section>
  ))}

  <!-- CLOSE -->
  <section class="scene scene--center" id="close" data-road="close" aria-labelledby="close-title">
    <div class="scene__media">
      <img src={media.close} alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" />
    </div>
    <div class="scene__grade"></div>
    <div class="scene__scrim"></div>
    <div class="wrap"><div class="panel">
      <h2 class="vh" id="close-title">In closing</h2>
      <p class="close-prose reveal">{close.body}</p>
    </div></div>
  </section>
</main>

<footer>
  <div class="foot-wrap">
    <div class="foot-name">{footer.name}</div>
    <div class="foot-meta">{footer.place}</div>
    <div class="foot-actions">
      <a class="foot-link" href={footer.link.href}>{footer.link.label}</a>
      <a class="foot-email" href={`mailto:${footer.email}`}>{footer.email}</a>
    </div>
    <p class="credit">
      Photography via Unsplash:{' '}
      {photoCredits.map((c, i) => (
        <>
          <a href={c.profile} target="_blank" rel="noopener noreferrer">{c.name}</a>{i < photoCredits.length - 1 ? ', ' : '.'}
        </>
      ))}
    </p>
  </div>
</footer>

<style is:global>
  /* ===== THE ROAD landing (tokens/reset/body live in global.css) ===== */
  main { position: relative; z-index: 1; }

  #road { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: var(--z-road); pointer-events: none; overflow: visible; }
  #road-ghost { fill: none; stroke: var(--ghost); stroke-width: 1.5; stroke-linecap: round; }
  #road-fill { fill: none; stroke: var(--amber); stroke-width: 2.4; stroke-linecap: round; filter: drop-shadow(0 0 5px rgba(245,166,35,.45)); }
  .head-halo { fill: rgba(245,166,35,.16); }
  .head-core { fill: #FFE6B8; }
  #road-head { filter: drop-shadow(0 0 10px rgba(245,166,35,.85)); }

  .valley-dim {
    position: fixed; inset: 0; z-index: 3; pointer-events: none;
    background: radial-gradient(120% 90% at 50% 60%, rgba(6,4,2,0), rgba(6,4,2,.55));
    opacity: 0; transition: opacity .6s ease;
  }
  body.at-valley .valley-dim { opacity: 1; }

  .scene { position: relative; min-height: 100vh; min-height: 100svh; display: flex; align-items: center; padding-block: 14vh; }
  .scene__media {
    position: absolute; inset: 0; z-index: 1; overflow: hidden;
    background: radial-gradient(120% 100% at 30% 20%, rgba(120,70,20,.20), transparent 60%), linear-gradient(180deg, #15100A, #0C0A07);
  }
  .scene--valley .scene__media { background: radial-gradient(120% 100% at 70% 30%, rgba(90,52,16,.18), transparent 60%), linear-gradient(180deg, #0E0A06, #080603); }
  .scene__media img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.86) brightness(.60) sepia(.30) contrast(1.04); }
  .scene--valley .scene__media img { filter: saturate(.74) brightness(.46) sepia(.34) contrast(1.06); }
  .scene__grade { position: absolute; inset: 0; z-index: 2; pointer-events: none; background: linear-gradient(180deg, rgba(12,10,7,.30), rgba(12,10,7,.12) 38%, rgba(12,10,7,.46)); mix-blend-mode: multiply; }
  .scene__scrim { position: absolute; inset: 0; z-index: 3; pointer-events: none; }
  .scene--left .scene__scrim { background: linear-gradient(90deg, rgba(10,8,5,.93) 0%, rgba(10,8,5,.80) 30%, rgba(10,8,5,.30) 60%, transparent 82%); }
  .scene--right .scene__scrim { background: linear-gradient(270deg, rgba(10,8,5,.93) 0%, rgba(10,8,5,.80) 30%, rgba(10,8,5,.30) 60%, transparent 82%); }
  .scene--center .scene__scrim { background: linear-gradient(180deg, rgba(10,8,5,.62), rgba(10,8,5,.86)); }
  .scene--valley .scene__scrim { filter: brightness(.9); }

  .wrap { position: relative; z-index: var(--z-content); width: 100%; max-width: var(--maxw); margin: 0 auto; padding-inline: var(--gut); }
  .panel { width: clamp(20rem, 42vw, 40rem); max-width: 100%; }
  .scene--right .panel { margin-left: auto; text-align: left; }
  .scene--center .panel { margin-inline: auto; text-align: center; width: min(46rem, 100%); }

  .ident { font-family: var(--mono); font-size: 12px; letter-spacing: .32em; text-transform: uppercase; color: var(--muted); margin-bottom: clamp(20px, 4vh, 42px); }
  .intro-title { font-family: var(--serif); font-weight: 560; font-size: clamp(4.2rem, 15vw, 12rem); line-height: .82; letter-spacing: -.045em; font-variation-settings: 'opsz' 144; margin-bottom: clamp(28px, 5vh, 56px); color: var(--paper); }
  .intro-title .br { display: block; }
  .lede { font-family: var(--serif); font-weight: 360; font-size: clamp(1.18rem, 1.9vw, 1.62rem); line-height: 1.5; letter-spacing: -.012em; color: #e6ddcd; max-width: 48ch; font-variation-settings: 'opsz' 72, 'SOFT' 20; }

  .stage-head { display: flex; align-items: baseline; gap: clamp(14px, 2vw, 28px); margin-bottom: clamp(20px, 3vh, 34px); }
  .stage-num { font-family: var(--serif); font-weight: 300; font-variation-settings: 'opsz' 144; font-size: clamp(2.8rem, 6vw, 5.2rem); line-height: .78; letter-spacing: -.03em; color: var(--amber); opacity: .62; transition: opacity .7s ease; }
  .scene.is-active .stage-num { opacity: 1; }
  .stage-title { font-family: var(--serif); font-weight: 480; font-variation-settings: 'opsz' 144; font-size: clamp(2rem, 4.6vw, 3.7rem); line-height: 1; letter-spacing: -.03em; color: var(--paper); }
  .scene--valley .stage-title { font-style: italic; font-variation-settings: 'opsz' 144, 'WONK' 1, 'SOFT' 30; }

  .kills { margin-bottom: clamp(22px, 3.4vh, 34px); }
  .kills__label { font-family: var(--mono); font-size: 10px; letter-spacing: .26em; text-transform: uppercase; color: var(--muted-2); display: block; margin-bottom: 12px; }
  .kills ul { list-style: none; }
  .kills li { font-family: var(--mono); font-weight: 300; font-size: clamp(.78rem, .96vw, .9rem); line-height: 1.5; color: var(--muted); padding: 8px 0 8px 24px; position: relative; border-top: 1px solid rgba(237,230,217,.07); }
  .kills li:first-child { border-top: 0; }
  .kills li::before { content: ""; position: absolute; left: 0; top: .95em; width: 12px; height: 1px; background: var(--muted-2); }

  .prose { font-family: var(--serif); font-weight: 380; font-size: clamp(1.18rem, 1.65vw, 1.5rem); line-height: 1.5; letter-spacing: -.01em; color: var(--paper); max-width: 40ch; font-variation-settings: 'opsz' 60, 'SOFT' 14; }
  .prose .accent { font-style: italic; color: var(--amber); font-variation-settings: 'opsz' 60, 'WONK' 1, 'SOFT' 50; line-height: 1.1; }
  .receipt { margin-top: clamp(24px, 3.4vh, 40px); font-family: var(--mono); font-weight: 400; font-size: clamp(.74rem, .92vw, .86rem); letter-spacing: .01em; color: var(--muted); line-height: 1.5; }
  .receipt__label { display: inline-block; font-size: 9.5px; letter-spacing: .28em; text-transform: uppercase; color: var(--muted-2); margin-right: 10px; }

  .close-prose { font-family: var(--serif); font-weight: 380; font-size: clamp(1.3rem, 2.5vw, 2.15rem); line-height: 1.42; letter-spacing: -.018em; color: #ece4d4; font-variation-settings: 'opsz' 96, 'SOFT' 16; }

  footer { position: relative; z-index: var(--z-footer); background: var(--ink-2); padding: clamp(64px, 12vh, 140px) var(--gut) clamp(40px, 7vh, 72px); border-top: 1px solid rgba(237,230,217,.08); }
  .foot-wrap { max-width: var(--maxw); margin: 0 auto; }
  .foot-name { font-family: var(--serif); font-weight: 520; font-size: clamp(2rem, 5vw, 3.4rem); letter-spacing: -.03em; line-height: 1; font-variation-settings: 'opsz' 144; }
  .foot-meta { font-family: var(--mono); font-size: 12px; letter-spacing: .2em; text-transform: uppercase; color: var(--muted); margin-top: 14px; }
  .foot-actions { display: flex; flex-wrap: wrap; gap: clamp(20px, 4vw, 56px); align-items: baseline; margin-top: clamp(36px, 6vh, 64px); }
  .foot-link { font-family: var(--serif); font-style: italic; font-weight: 400; font-size: clamp(1.15rem, 1.8vw, 1.5rem); color: var(--paper); border-bottom: 1px solid rgba(237,230,217,.35); padding-bottom: 4px; transition: border-color .3s ease; }
  .foot-link:hover { border-color: var(--paper); }
  .foot-email { font-family: var(--mono); font-size: 13px; letter-spacing: .04em; color: var(--muted); border-bottom: 1px solid transparent; padding-bottom: 4px; transition: color .3s, border-color .3s; }
  .foot-email:hover { color: var(--paper); border-color: rgba(237,230,217,.3); }
  .credit { margin-top: clamp(40px, 7vh, 72px); font-family: var(--mono); font-size: 10.5px; line-height: 1.7; letter-spacing: .02em; color: var(--muted-2); max-width: 60ch; }
  .credit a { color: var(--muted); text-decoration: underline; text-underline-offset: 2px; }
  .credit a:hover { color: var(--paper); }

  @media (max-width: 820px) {
    #road, .valley-dim { display: none; }
    .scene { padding-block: 12vh; }
    .panel, .scene--right .panel, .scene--center .panel { width: 100%; margin: 0; text-align: left; }
    .scene--left .scene__scrim, .scene--right .scene__scrim, .scene--center .scene__scrim { background: linear-gradient(180deg, rgba(10,8,5,.55), rgba(10,8,5,.88)); }
  }

  @media (forced-colors: active) {
    #road, .valley-dim, .scene__grade, .scene__scrim { display: none; }
    .prose .accent { font-style: italic; text-decoration: underline; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const REDUCE = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DESKTOP = window.matchMedia && window.matchMedia('(min-width: 821px)').matches;

  const main = document.getElementById('main')!;
  const fill = document.getElementById('road-fill') as SVGPathElement | null;
  const ghost = document.getElementById('road-ghost') as SVGPathElement | null;
  const head = document.getElementById('road-head');
  const halo = head?.querySelector('.head-halo') as SVGCircleElement | null;
  const core = head?.querySelector('.head-core') as SVGCircleElement | null;
  const svg = document.getElementById('road') as SVGSVGElement | null;

  // road rides the EMPTY (image) side opposite the text, dipping at the valley.
  const ANCHORS = [
    { id: 'intro', xf: 0.50, yk: 0.62 },
    { id: 's1', xf: 0.30, yk: 0.50 },
    { id: 's2', xf: 0.70, yk: 0.50 },
    { id: 's3', xf: 0.30, yk: 0.42 },
    { id: 's3', xf: 0.17, yk: 0.90 }, // valley floor (the dip)
    { id: 's4', xf: 0.70, yk: 0.50 },
    { id: 'close', xf: 0.50, yk: 0.50 },
  ];

  let W = 0, H = 0, total = 0, valleyLen = 0, valleyY = 0;
  let LUT: { y: number; len: number; x: number }[] = [];

  function catmullRom(pts: number[][]): string {
    if (pts.length < 2) return '';
    let d = 'M ' + pts[0][0].toFixed(1) + ' ' + pts[0][1].toFixed(1);
    for (let i = 0; i < pts.length - 1; i++) {
      const p0 = pts[i - 1] || pts[i], p1 = pts[i], p2 = pts[i + 1], p3 = pts[i + 2] || pts[i + 1];
      const c1x = p1[0] + (p2[0] - p0[0]) / 6, c1y = p1[1] + (p2[1] - p0[1]) / 6;
      const c2x = p2[0] - (p3[0] - p1[0]) / 6, c2y = p2[1] - (p3[1] - p1[1]) / 6;
      d += ' C ' + c1x.toFixed(1) + ' ' + c1y.toFixed(1) + ', ' + c2x.toFixed(1) + ' ' + c2y.toFixed(1) + ', ' + p2[0].toFixed(1) + ' ' + p2[1].toFixed(1);
    }
    return d;
  }

  function build() {
    if (!svg || !fill || !ghost) return;
    W = main.clientWidth;
    H = main.scrollHeight;
    svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
    svg.style.height = H + 'px';

    const pts: number[][] = [];
    const s3 = document.getElementById('s3');
    if (s3) valleyY = s3.offsetTop + s3.offsetHeight * 0.90;
    for (const a of ANCHORS) {
      const el = document.getElementById(a.id);
      if (!el) continue;
      pts.push([W * a.xf, el.offsetTop + el.offsetHeight * a.yk]);
    }
    for (let j = 1; j < pts.length; j++) { if (pts[j][1] <= pts[j - 1][1]) pts[j][1] = pts[j - 1][1] + 1; }

    const d = catmullRom(pts);
    ghost.setAttribute('d', d);
    fill.setAttribute('d', d);

    total = fill.getTotalLength();
    fill.style.strokeDasharray = String(total);
    fill.style.strokeDashoffset = String(total);

    LUT = [];
    const N = 240;
    for (let k = 0; k <= N; k++) {
      const L = total * k / N, p = fill.getPointAtLength(L);
      LUT.push({ y: p.y, len: L, x: p.x });
    }
    valleyLen = lookup(valleyY).len;
  }

  function lookup(y: number) {
    if (!LUT.length) return { y, len: 0, x: 0 };
    if (y <= LUT[0].y) return LUT[0];
    if (y >= LUT[LUT.length - 1].y) return LUT[LUT.length - 1];
    let lo = 0, hi = LUT.length - 1;
    while (hi - lo > 1) { const mid = (lo + hi) >> 1; if (LUT[mid].y < y) lo = mid; else hi = mid; }
    const a = LUT[lo], b = LUT[hi], t = (y - a.y) / (b.y - a.y || 1);
    return { y, len: a.len + (b.len - a.len) * t, x: a.x + (b.x - a.x) * t };
  }

  function place(x: number, y: number) {
    halo?.setAttribute('cx', String(x)); halo?.setAttribute('cy', String(y));
    core?.setAttribute('cx', String(x)); core?.setAttribute('cy', String(y));
  }

  function render(progress: number) {
    if (!fill) return;
    const vh = window.innerHeight;
    const headY = progress * (H - vh) + vh * 0.5;
    const r = lookup(headY);
    fill.style.strokeDashoffset = String(total - r.len);
    place(r.x, r.y);
  }

  function renderStatic() {
    if (!fill) return;
    fill.style.strokeDashoffset = String(total - valleyLen);
    const p = LUT.length ? lookup(valleyY) : { x: W * 0.17, y: valleyY };
    place(p.x, p.y);
  }

  const roadOn = DESKTOP && !!svg;

  if (REDUCE) {
    if (roadOn) { build(); renderStatic(); window.addEventListener('resize', () => { build(); renderStatic(); }); }
  } else {
    gsap.registerPlugin(ScrollTrigger);

    if (roadOn) {
      build();
      render(0);
      ScrollTrigger.create({
        trigger: document.documentElement, start: 'top top', end: 'bottom bottom', scrub: true,
        onUpdate: (s) => render(s.progress),
        onRefresh: (s) => { build(); render(s.progress); },
      });
    }

    gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
      gsap.from(el, { opacity: 0, y: 18, duration: 0.8, ease: 'power3.out', scrollTrigger: { trigger: el, start: 'top 88%' } });
    });

    document.querySelectorAll<HTMLElement>('[data-stage]').forEach((sec) => {
      ScrollTrigger.create({ trigger: sec, start: 'top 55%', end: 'bottom 45%', onToggle: (s) => sec.classList.toggle('is-active', s.isActive) });
    });

    ScrollTrigger.create({
      trigger: '#s3', start: 'top 60%', end: 'bottom 40%',
      onToggle: (s) => {
        document.body.classList.toggle('at-valley', s.isActive);
        if (roadOn && halo) gsap.to(halo, { attr: { r: s.isActive ? 19 : 13 }, duration: 0.7, ease: 'sine.inOut' });
      },
    });

    if (document.fonts && document.fonts.ready) { document.fonts.ready.then(() => ScrollTrigger.refresh()); }
    window.addEventListener('load', () => ScrollTrigger.refresh());
  }
</script>
