---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SiteFooter from '../../components/SiteFooter.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base title={`${post.data.title} · Anubhav Das`} description={post.data.dek}>
  <div class="progress" id="progress" aria-hidden="true"></div>

  <main id="main" class="article page-enter">
    <article class="prose-wrap">
      <a class="back" href="/writing">Writing</a>
      <header class="art-head">
        <p class="art-date">{fmt(post.data.date)}{post.data.readingMinutes ? ` · ${post.data.readingMinutes} min read` : ''}</p>
        <h1 class="art-title">{post.data.title}</h1>
        <p class="art-dek">{post.data.dek}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>

  <SiteFooter />
</Base>

<style>
  /* the amber reading-progress thread (an amber home on this page) */
  .progress { position: fixed; top: 0; left: 0; height: 2px; width: 0; z-index: var(--z-nav); background: var(--amber); box-shadow: 0 0 10px rgba(245,166,35,.6); }

  .article { padding-top: clamp(104px, 15vh, 168px); padding-inline: var(--gut); }
  .prose-wrap { max-width: 40rem; margin: 0 auto; }

  .back { display: inline-block; font-family: var(--mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--muted); margin-bottom: clamp(28px, 5vh, 52px); border-bottom: 1px solid transparent; padding-bottom: 3px; transition: color .25s, border-color .25s; }
  .back:hover { color: var(--paper); border-color: rgba(237,230,217,.3); }
  .back::before { content: '\2190  '; }

  .art-date { font-family: var(--mono); font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted); }
  .art-title { font-family: var(--serif); font-weight: 500; font-size: clamp(2.2rem, 5vw, 3.6rem); line-height: 1.05; letter-spacing: -.035em; color: var(--paper); margin-top: 16px; text-wrap: balance; }
  .art-dek { font-family: var(--serif); font-weight: 360; font-style: italic; font-size: clamp(1.2rem, 1.9vw, 1.5rem); line-height: 1.45; color: var(--paper-dim); margin-top: 20px; text-wrap: pretty; }

  .prose { margin-top: clamp(40px, 7vh, 72px); }
  .prose :global(p) { font-family: var(--serif); font-weight: 380; font-size: clamp(1.12rem, 1.45vw, 1.3rem); line-height: 1.62; color: var(--paper); margin-bottom: 1.4em; font-variation-settings: 'opsz' 40; text-wrap: pretty; }
  .prose :global(h2) { font-family: var(--serif); font-weight: 500; font-size: clamp(1.5rem, 2.6vw, 2rem); line-height: 1.15; letter-spacing: -.02em; color: var(--paper); margin: 1.8em 0 .6em; }
  .prose :global(h3) { font-family: var(--serif); font-weight: 500; font-size: clamp(1.25rem, 2vw, 1.5rem); color: var(--paper); margin: 1.6em 0 .5em; }
  .prose :global(a) { color: var(--paper); border-bottom: 1px solid rgba(237,230,217,.35); }
  .prose :global(a:hover) { border-color: var(--paper); }
  .prose :global(strong) { font-weight: 600; color: var(--paper); }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.4em 1.2em; }
  .prose :global(li) { font-family: var(--serif); font-size: clamp(1.08rem, 1.4vw, 1.25rem); line-height: 1.6; color: var(--paper); margin-bottom: .5em; }
  /* the amber pull-quote (an amber home on this page) — borderless, set off by
     whitespace + a full hairline, not a side stripe. */
  .prose :global(blockquote) {
    margin: clamp(40px, 7vh, 72px) auto; padding: clamp(24px, 4vh, 40px) 0 0;
    max-width: 34ch; border-top: 1px solid rgba(237,230,217,.16);
    font-family: var(--serif); font-style: italic; font-weight: 420;
    font-size: clamp(1.5rem, 2.8vw, 2.1rem); line-height: 1.32; letter-spacing: -.015em; color: var(--amber);
    font-variation-settings: 'opsz' 72, 'WONK' 1, 'SOFT' 40;
  }
  .prose :global(blockquote p) { font: inherit; color: inherit; margin: 0; }
</style>

<script>
  const bar = document.getElementById('progress');
  if (bar) {
    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      bar.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + '%';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  }
</script>
