<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const REDUCE = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DESKTOP = window.matchMedia('(min-width: 821px)').matches;
  const fillEl = document.getElementById('progress-fill');

  // charts already show their finished state; JS only adds draw-in + the thread
  if (!REDUCE) {
    gsap.registerPlugin(ScrollTrigger);

    if (DESKTOP && fillEl) {
      ScrollTrigger.create({
        trigger: document.documentElement, start: 'top top', end: 'bottom bottom', scrub: true,
        onUpdate: (s) => { (fillEl as HTMLElement).style.transform = 'scaleY(' + s.progress.toFixed(4) + ')'; },
      });
    }
    gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
      gsap.from(el, { opacity: 0, y: 16, duration: 0.75, ease: 'power3.out', scrollTrigger: { trigger: el, start: 'top 90%' } });
    });
    gsap.utils.toArray<HTMLElement>('.figures .fig').forEach((el, i) => {
      gsap.from(el, { opacity: 0, y: 16, duration: 0.6, delay: i * 0.06, ease: 'power3.out', scrollTrigger: { trigger: '.figures', start: 'top 84%' } });
    });
    gsap.utils.toArray<SVGElement>('.chart .bar').forEach((el) => {
      el.style.transformBox = 'fill-box'; el.style.transformOrigin = 'left center';
      gsap.from(el, { scaleX: 0, duration: 0.9, ease: 'power3.out', scrollTrigger: { trigger: el.closest('figure'), start: 'top 78%' } });
    });
    gsap.utils.toArray<SVGElement>('.chart .vbar').forEach((el) => {
      el.style.transformBox = 'fill-box'; el.style.transformOrigin = 'center bottom';
      gsap.from(el, { scaleY: 0, duration: 0.9, ease: 'power3.out', scrollTrigger: { trigger: el.closest('figure'), start: 'top 78%' } });
    });
    gsap.utils.toArray<SVGGeometryElement>('.chart polyline').forEach((el) => {
      if (el.getAttribute('stroke-dasharray')) return; // dashed reference lines keep their pattern
      const len = el.getTotalLength ? el.getTotalLength() : 1200;
      el.style.strokeDasharray = String(len); el.style.strokeDashoffset = String(len);
      gsap.to(el, { strokeDashoffset: 0, duration: 1.4, ease: 'power2.out', scrollTrigger: { trigger: el.closest('figure'), start: 'top 74%' } });
    });
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => ScrollTrigger.refresh());
    window.addEventListener('load', () => ScrollTrigger.refresh());
  }
</script>
